---
import Layout from "../layouts/Layout.astro";

const includes = [
  {
    number: "01",
    title: "Entrenamiento diario dirigido a tus metas",
    desc: "Rutinas estructuradas para ayudarte a avanzar de forma progresiva durante las 4 semanas.",
    color: "#a115ff",
  },
  {
    number: "02",
    title: "Nutrición flexible (sin dietas extremas)",
    desc: "Aprende a alimentarte mejor sin restricciones extremas ni culpas innecesarias.",
    color: "#7ef474",
  },
  {
    number: "03",
    title: "Apoyo mental + emocional",
    desc: "Herramientas para trabajar el enfoque, la calma y la disciplina durante el proceso.",
    color: "#a115ff",
  },
  {
    number: "04",
    title: "Tribu LYT – Comunidad para ti",
    desc: "Acceso a una comunidad que te acompaña, motiva y sostiene durante todo el reto.",
    color: "#7ef474",
  },
];

const steps = [
  "Te inscribes y aseguras tu cupo",
  "Recibes acceso al contenido y a la comunidad",
  "Sigues el plan durante 4 semanas (entrenamiento, nutrición y mindset)",
  "Empiezas a notar cambios reales en tu cuerpo, energía y hábitos",
];

const transformations = [
  "Más energía en tu día a día",
  "Mayor enfoque y claridad mental",
  "Constancia y hábitos sostenibles",
  "Menos culpa, más equilibrio",
  "Una mejor relación con tu cuerpo",
];

const paraQuien = [
  "Quieres retomar el ejercicio con estructura y guía",
  "Buscas constancia sin rutinas imposibles",
  "Te cuesta mantener la motivación por tu cuenta",
  "Quieres mejorar tu relación con el ejercicio y la comida",
  "No importa tu nivel, edad o país donde te encuentres",
];

const priceIncludes = [
  "Entrenamiento diario estructurado",
  "Nutrición flexible sin restricciones",
  "Apoyo mental y emocional",
  "Acceso a la Tribu LYT",
  "4 semanas de acompañamiento completo",
];

const paymentMethods = ["Zelle", "PayPal", "Western Union"];

// Reemplaza con el ID de tu video de YouTube (lo que va después de ?v= en la URL)
// Ejemplo: https://www.youtube.com/watch?v=dQw4w9WgXcQ → VIDEO_ID = 'dQw4w9WgXcQ'
const VIDEO_ID = "PRT3sN5klk0";
---

<Layout>
  <!-- ===== NAVBAR ===== -->
  <header
    class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-md border-b border-white/10"
  >
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <span class="text-lg font-black tracking-tight text-white"
        >SoyNathaFit</span
      >
      <a
        href="#precio"
        class="bg-[#7ef474] hover:bg-[#65d95e] text-black text-sm font-bold px-5 py-2.5 rounded-full transition-colors"
      >
        Únete al reto
      </a>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Orbes de fondo -->
    <div
      class="absolute top-1/4 -left-40 w-[500px] h-[500px] bg-[#a115ff] opacity-[0.15] rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-1/4 -right-40 w-[500px] h-[500px] bg-[#7ef474] opacity-[0.08] rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 pt-28 pb-20 w-full">
      <!-- FILA SUPERIOR: Eyebrow + Título + Descripción (ancho completo) -->
      <div class="mb-12">
        <!-- Eyebrow -->
        <div
          class="inline-flex items-center gap-2.5 bg-white/5 border border-white/10 rounded-full px-4 py-2 mb-8"
        >
          <span
            class="w-2 h-2 bg-[#7ef474] rounded-full animate-pulse flex-shrink-0"
          ></span>
          <span class="text-sm text-gray-300 font-medium"
            >Reto Online Masivo by SoyNathaFit</span
          >
        </div>

        <!-- Headline -->
        <h1
          class="text-6xl lg:text-7xl font-black leading-[0.92] text-white mb-6 tracking-tight max-w-4xl"
        >
          Transforma tu cuerpo y tu mente en
          <span class="text-[#a115ff]"> 4 semanas</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-gray-400 text-xl leading-relaxed max-w-2xl">
          Entrenamiento, nutrición flexible y apoyo mental en un solo programa
          100% online, diseñado para acompañarte desde cualquier parte del
          mundo.
        </p>
      </div>

      <!-- FILA INFERIOR: dos columnas -->
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <!-- Columna izquierda: Pills + Precio + CTA -->
        <div>
          <!-- Pills -->
          <div class="flex flex-wrap gap-3 mb-10">
            <span
              class="border border-[#7ef474]/40 text-[#7ef474] text-sm font-semibold px-4 py-2 rounded-full bg-[#7ef474]/5"
            >
              ✓ 100% online · Acceso internacional
            </span>
            <span
              class="border border-white/15 text-gray-300 text-sm font-semibold px-4 py-2 rounded-full bg-white/5"
            >
              ✓ Duración: 4 semanas
            </span>
            <span
              class="border border-white/15 text-gray-300 text-sm font-semibold px-4 py-2 rounded-full bg-white/5"
            >
              ✓ Inicio: lunes 2 de marzo
            </span>
          </div>

          <!-- Precio -->
          <div class="flex items-baseline gap-5 mb-10">
            <span class="text-gray-500 line-through text-2xl font-semibold"
              >$53 USD</span
            >
            <div class="flex items-baseline gap-2">
              <span class="text-white text-7xl font-black">$28</span>
              <span class="text-gray-400 text-2xl font-semibold">USD</span>
            </div>
          </div>

          <!-- CTA -->
          <div
            class="flex flex-col sm:flex-row items-start sm:items-center gap-4"
          >
            <a
              href="#precio"
              class="bg-[#7ef474] hover:bg-[#65d95e] text-black text-lg font-black px-10 py-5 rounded-full transition-all hover:scale-[1.03] shadow-2xl shadow-[#7ef474]/20 inline-block"
            >
              Únete al reto ahora →
            </a>
            <span class="text-gray-500 text-sm"
              >Precio especial por tiempo limitado</span
            >
          </div>
        </div>

        <!-- Columna derecha: Video -->
        <div class="lg:sticky lg:top-24">
          <div
            class="relative rounded-2xl overflow-hidden border border-white/10 bg-[#111] shadow-2xl shadow-black/60"
          >
            {
              VIDEO_ID ? (
                <div class="aspect-video w-full">
                  <iframe
                    src={`https://www.youtube.com/embed/${VIDEO_ID}?rel=0&modestbranding=1`}
                    title="SoyNathaFit – Reto Online Masivo"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    class="w-full h-full"
                  />
                </div>
              ) : (
                <div class="aspect-video w-full flex flex-col items-center justify-center bg-gradient-to-br from-[#1a1a1a] to-[#111] gap-4">
                  <div class="w-16 h-16 rounded-full bg-[#a115ff]/20 border border-[#a115ff]/40 flex items-center justify-center">
                    <svg
                      class="w-7 h-7 text-[#a115ff] ml-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                  <p class="text-gray-500 text-sm font-medium">Tu video aquí</p>
                  <p class="text-gray-600 text-xs px-8 text-center">
                    Agrega tu VIDEO_ID en{" "}
                    <code class="text-[#7ef474]/70">index.astro</code>
                  </p>
                </div>
              )
            }
            <div
              class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-2xl pointer-events-none"
            >
            </div>
          </div>
          <p class="text-center text-gray-600 text-sm mt-4 font-medium">
            Conoce el programa antes de inscribirte
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ¿PARA QUIÉN ES? ===== -->
  <section class="py-28 bg-[#0d0d0d]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Texto izquierdo -->
        <div>
          <p
            class="text-[#a115ff] font-bold text-sm uppercase tracking-widest mb-4"
          >
            ¿Para quién es?
          </p>
          <h2
            class="text-4xl lg:text-5xl font-black text-white mb-6 leading-tight"
          >
            Este reto es para ti si…
          </h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-10">
            Este programa está diseñado para personas reales que buscan
            resultados sostenibles, sin extremos ni presiones innecesarias.
          </p>
          <ul class="space-y-4">
            {
              paraQuien.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="flex-shrink-0 mt-1 w-5 h-5 rounded-full bg-[#a115ff]/15 border border-[#a115ff]/40 flex items-center justify-center">
                    <span class="w-2 h-2 bg-[#a115ff] rounded-full" />
                  </span>
                  <span class="text-gray-200 text-lg">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Card cierre -->
        <div class="bg-[#111] border border-white/10 rounded-3xl p-10">
          <p
            class="text-2xl lg:text-3xl font-black text-white leading-snug mb-5"
          >
            "No necesitas estar en tu mejor forma para empezar."
          </p>
          <p class="text-xl text-[#7ef474] font-black">
            Solo necesitas decidirte.
          </p>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="#precio"
              class="inline-block bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold px-6 py-3 rounded-full transition-colors text-sm"
            >
              Ver precio del reto →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ¿QUÉ INCLUYE? ===== -->
  <section class="py-28 bg-[#080808]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p
          class="text-[#7ef474] font-bold text-sm uppercase tracking-widest mb-4"
        >
          ¿Qué incluye?
        </p>
        <h2 class="text-4xl lg:text-5xl font-black text-white">
          Todo lo que necesitas,<br />a un click de distancia
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {
          includes.map((item) => (
            <div class="bg-[#111] border border-white/10 hover:border-white/20 rounded-2xl p-8 transition-all hover:bg-[#151515] group">
              <div
                class="text-5xl font-black mb-6 leading-none"
                style={`color: ${item.color}; opacity: 0.25;`}
              >
                {item.number}
              </div>
              <h3 class="text-xl font-black text-white mb-3 leading-snug">
                {item.title}
              </h3>
              <p class="text-gray-400 leading-relaxed">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== ¿CÓMO FUNCIONA? ===== -->
  <section class="py-28 bg-[#0d0d0d]">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <p
          class="text-[#a115ff] font-bold text-sm uppercase tracking-widest mb-4"
        >
          El proceso
        </p>
        <h2 class="text-4xl lg:text-5xl font-black text-white">
          ¿Cómo funciona el reto?
        </h2>
      </div>

      <div class="space-y-4">
        {
          steps.map((text, i) => (
            <div class="flex items-center gap-6 bg-[#111] border border-white/10 hover:border-white/20 rounded-2xl p-6 transition-colors">
              <div class="flex-shrink-0 w-12 h-12 bg-[#a115ff] rounded-full flex items-center justify-center text-white font-black text-lg">
                {i + 1}
              </div>
              <p class="text-white text-lg font-semibold flex-1">{text}</p>
              {i < steps.length - 1 && (
                <span class="text-gray-700 text-xl hidden sm:block">›</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== TRANSFORMACIÓN ===== -->
  <section class="py-28 bg-[#080808]">
    <div class="max-w-6xl mx-auto px-6">
      <div
        class="bg-gradient-to-br from-[#a115ff]/10 via-transparent to-[#7ef474]/5 border border-white/10 rounded-3xl p-12 lg:p-16"
      >
        <div class="grid lg:grid-cols-2 gap-14 items-center">
          <div>
            <p
              class="text-[#7ef474] font-bold text-sm uppercase tracking-widest mb-4"
            >
              Transformación
            </p>
            <h2
              class="text-4xl lg:text-5xl font-black text-white mb-6 leading-tight"
            >
              Esto no es solo un reto físico
            </h2>
            <p class="text-gray-400 text-lg leading-relaxed">
              Este reto está pensado para ayudarte a crear estructura,
              disciplina y conexión contigo mismo, más allá del resultado
              estético.
            </p>
          </div>

          <ul class="space-y-5">
            {
              transformations.map((item) => (
                <li class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-6 h-6 bg-[#7ef474]/15 border border-[#7ef474]/40 rounded-full flex items-center justify-center">
                    <span class="text-[#7ef474] text-xs font-black">✓</span>
                  </span>
                  <span class="text-gray-200 text-lg">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRECIO ===== -->
  <section id="precio" class="py-28 bg-[#0d0d0d]">
    <div class="max-w-xl mx-auto px-6">
      <div class="text-center mb-12">
        <p
          class="text-[#a115ff] font-bold text-sm uppercase tracking-widest mb-4"
        >
          Oferta especial
        </p>
        <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight">
          Inscríbete hoy al<br />Reto Online Masivo
        </h2>
      </div>

      <div
        class="bg-[#111] border border-[#7ef474]/25 rounded-3xl p-10 text-center relative overflow-hidden"
      >
        <!-- Borde top degradado -->
        <div
          class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-[#a115ff] via-[#7ef474] to-[#a115ff]"
        >
        </div>

        <!-- Badge urgencia -->
        <div
          class="inline-flex items-center gap-2 bg-[#7ef474]/10 border border-[#7ef474]/30 rounded-full px-4 py-2 mb-8"
        >
          <span
            class="w-2 h-2 bg-[#7ef474] rounded-full animate-pulse flex-shrink-0"
          ></span>
          <span class="text-[#7ef474] text-sm font-semibold"
            >Precio especial por tiempo limitado</span
          >
        </div>

        <!-- Precio -->
        <div class="flex items-center justify-center gap-5 mb-8">
          <span class="text-gray-500 line-through text-xl font-semibold"
            >$53 USD</span
          >
          <div class="flex items-baseline gap-1">
            <span class="text-white text-7xl font-black">$28</span>
            <span class="text-gray-400 text-xl font-semibold">USD</span>
          </div>
        </div>

        <!-- Lista de beneficios -->
        <div class="space-y-3 text-left mb-10 max-w-xs mx-auto">
          {
            priceIncludes.map((item) => (
              <div class="flex items-center gap-3">
                <span class="text-[#7ef474] font-black flex-shrink-0">✓</span>
                <span class="text-gray-300">{item}</span>
              </div>
            ))
          }
        </div>

        <!-- CTA Button -->
        <a
          href="#"
          class="block w-full bg-[#7ef474] hover:bg-[#65d95e] text-black font-black text-xl py-5 rounded-full transition-all hover:scale-[1.02] shadow-xl shadow-[#7ef474]/20"
        >
          Quiero unirme al reto →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== MÉTODOS DE PAGO ===== -->
  <section class="py-20 bg-[#080808] border-t border-white/5">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h3 class="text-2xl font-black text-white mb-3">
        Métodos de pago disponibles
      </h3>
      <p class="text-gray-400 mb-10">
        Aceptamos los siguientes métodos de pago para participantes de todo el
        mundo:
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {
          paymentMethods.map((method) => (
            <div class="bg-[#111] border border-white/10 hover:border-white/20 transition-colors rounded-xl px-8 py-4 text-white font-bold">
              {method}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== FECHA DE INICIO ===== -->
  <section class="py-20 bg-[#0d0d0d]">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="bg-[#a115ff]/8 border border-[#a115ff]/25 rounded-3xl p-12">
        <p
          class="text-[#a115ff] font-bold text-sm uppercase tracking-widest mb-4"
        >
          Próxima fecha
        </p>
        <h3 class="text-3xl font-black text-white mb-4">Inicio oficial:</h3>
        <p class="text-5xl lg:text-6xl font-black text-[#7ef474] mb-6">
          Lunes 2 de marzo
        </p>
        <p class="text-gray-400 text-base">
          Los cupos son limitados para mantener la calidad del acompañamiento.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== SOBRE SOYNATHAFIT ===== -->
  <section class="py-28 bg-[#080808]">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <p
          class="text-[#7ef474] font-bold text-sm uppercase tracking-widest mb-4"
        >
          Sobre nosotros
        </p>
        <h2 class="text-4xl font-black text-white">Sobre SoyNathaFit</h2>
      </div>
      <div class="bg-[#111] border border-white/10 rounded-3xl p-10 lg:p-12">
        <p class="text-gray-300 text-lg leading-relaxed mb-6">
          SoyNathaFit es un enfoque integral de bienestar que combina
          entrenamiento, nutrición flexible y trabajo mental, ayudando a
          personas reales a construir hábitos sostenibles sin extremos.
        </p>
        <p class="text-gray-300 text-lg leading-relaxed">
          Este reto fue creado para acompañarte, guiarte y demostrarte que sí
          puedes sostener un proceso cuando tienes la estructura correcta.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="py-36 bg-[#0d0d0d] relative overflow-hidden">
    <div
      class="absolute inset-0 flex items-center justify-center pointer-events-none"
      aria-hidden="true"
    >
      <div
        class="w-[700px] h-[700px] bg-[#a115ff] opacity-[0.07] rounded-full blur-3xl"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
        Este puede ser tu punto de partida
      </h2>
      <p class="text-gray-400 text-xl mb-3">No esperes al momento perfecto.</p>
      <p class="text-gray-400 text-xl mb-14">
        Empieza hoy y acompáñanos durante estas 4 semanas.
      </p>
      <a
        href="#precio"
        class="inline-block bg-[#7ef474] hover:bg-[#65d95e] text-black font-black text-xl px-14 py-6 rounded-full transition-all hover:scale-[1.03] shadow-2xl shadow-[#7ef474]/20"
      >
        Únete al Reto Online Masivo ahora →
      </a>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="bg-black border-t border-white/10 py-8">
    <div
      class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <span class="text-white font-black text-lg">SoyNathaFit</span>
      <span class="text-gray-600 text-sm"
        >© 2025 SoyNathaFit. Todos los derechos reservados.</span
      >
    </div>
  </footer>
</Layout>
