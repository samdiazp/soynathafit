---
import Layout from "../../layouts/Layout.astro";
import { terminos } from "../../legal";
---

<Layout title="Formulario de Inscripción | SoyNathaFit">
  <div
    style="min-height: 100vh; padding: 3rem 1rem; background: linear-gradient(140deg, #4f6fe8 0%, #5b21b6 50%, #7c3aed 100%)"
  >
    <div class="max-w-2xl mx-auto">
      <!-- Logo -->
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-start gap-1">
          <span class="text-white/70 text-xs leading-none mt-1.5">by</span>
          <span class="text-white font-black text-2xl leading-none"
            >SōyNathaFit</span
          >
        </a>
      </div>

      <!-- Success State -->
      <div
        id="success-state"
        class="hidden bg-white rounded-3xl shadow-2xl px-16 py-12 text-center"
      >
        <div
          class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 mt-2"
          style="background-color: #dcfce7"
        >
          <span class="text-4xl" style="color: #16a34a">✓</span>
        </div>
        <h2 class="font-black text-[#1e3a5f] text-2xl mb-4">
          ¡Solicitud enviada!
        </h2>
        <p class="text-[#1e3a5f]/70 mb-2 leading-relaxed">
          Tu solicitud fue recibida. Revisaremos tu comprobante de pago y te
          contactaremos pronto.
        </p>
        <p class="text-sm text-[#1e3a5f]/40">
          Si tienes preguntas, contáctanos por Instagram o WhatsApp.
        </p>
        <a
          href="/"
          class="inline-block mt-8 bg-[#e8601c] hover:bg-[#cf5218] text-white font-black text-sm uppercase tracking-wide px-8 py-3 rounded-full transition-all my-8"
        >
          Volver al inicio
        </a>
      </div>

      <!-- Form Card -->
      <div
        id="form-card"
        class="bg-white rounded-3xl shadow-2xl overflow-hidden p-4"
      >
        <!-- Card Header -->
        <div class="px-8 pt-8 pb-6 border-b border-[#1e3a5f]/8">
          <h1 class="font-black text-[#1e3a5f] text-2xl">
            Formulario de Inscripción
          </h1>
          <p class="text-[#1e3a5f]/60 text-sm mt-0.5">
            Reto Online Masivo · SōyNathaFit
          </p>
          <p
            id="step-label"
            class="text-[#1e3a5f]/40 text-xs mt-1 font-medium uppercase tracking-widest"
          >
            Paso 1 de 7
          </p>
          <!-- Progress bars -->
          <div class="flex gap-1.5 mt-3">
            {
              Array.from({ length: 7 }).map((_, i) => (
                <div
                  id={`bar-${i + 1}`}
                  class="h-1.5 flex-1 rounded-full transition-all duration-300"
                  style="background-color: rgba(30,58,95,0.1)"
                />
              ))
            }
          </div>
        </div>

        <!-- Global error -->
        <div
          id="global-error"
          class="hidden mx-8 mt-4 rounded-xl p-3 text-sm"
          style="background-color: #fef2f2; border: 1px solid #fecaca; color: #dc2626"
        >
        </div>

        <!-- ===== STEP 1: Email ===== -->
        <div id="step-1" class="px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Correo electrónico
          </h3>
          <div class="space-y-1.5">
            <label for="f-email" class="label-text">
              Correo electrónico <span class="text-red-500">*</span>
            </label>
            <input
              id="f-email"
              type="email"
              placeholder="tu@correo.com"
              class="form-input"
            />
            <p id="err-email" class="err-msg hidden"></p>
          </div>
          <div class="flex justify-end pt-2">
            <button type="button" onclick="goNext()" class="btn-primary"
              >Siguiente →</button
            >
          </div>
        </div>

        <!-- ===== STEP 2: Personal Info ===== -->
        <div id="step-2" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Información personal
          </h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="f-firstName" class="label-text">
                Nombre <span class="text-red-500">*</span>
              </label>
              <input id="f-firstName" type="text" class="form-input" />
              <p id="err-firstName" class="err-msg hidden"></p>
            </div>
            <div class="space-y-1.5">
              <label for="f-lastName" class="label-text">
                Apellido <span class="text-red-500">*</span>
              </label>
              <input id="f-lastName" type="text" class="form-input" />
              <p id="err-lastName" class="err-msg hidden"></p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="f-age" class="label-text">
                Edad <span class="text-red-500">*</span>
              </label>
              <input
                id="f-age"
                type="number"
                min="1"
                max="120"
                placeholder="25"
                class="form-input"
              />
              <p id="err-age" class="err-msg hidden"></p>
            </div>
            <div class="space-y-1.5">
              <label for="f-gender" class="label-text">
                Género <span class="text-red-500">*</span>
              </label>
              <select id="f-gender" class="form-input">
                <option value="">Selecciona</option>
                <option value="female">Femenino</option>
                <option value="male">Masculino</option>
              </select>
              <p id="err-gender" class="err-msg hidden"></p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="f-phone" class="label-text">Teléfono</label>
              <input
                id="f-phone"
                type="tel"
                placeholder="+1 (555) 000-0000"
                class="form-input"
              />
            </div>
            <div class="space-y-1.5">
              <label for="f-country" class="label-text"
                >País de residencia</label
              >
              <select id="f-country" class="form-input">
                <option value="">Selecciona un país</option>
              </select>
            </div>
          </div>
          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button type="button" onclick="goNext()" class="btn-primary"
              >Siguiente →</button
            >
          </div>
        </div>

        <!-- ===== STEP 3: Physical Measurements ===== -->
        <div id="step-3" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Medidas físicas
          </h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="f-weight" class="label-text">
                Peso (lbs) <span class="text-red-500">*</span>
              </label>
              <input
                id="f-weight"
                type="number"
                step="0.1"
                min="0"
                placeholder="154"
                class="form-input"
              />
              <p id="err-weight" class="err-msg hidden"></p>
            </div>
            <div class="space-y-1.5">
              <label for="f-height" class="label-text">
                Altura (inches) <span class="text-red-500">*</span>
              </label>
              <input
                id="f-height"
                type="number"
                step="0.1"
                min="0"
                placeholder="67"
                class="form-input"
              />
              <p id="err-height" class="err-msg hidden"></p>
            </div>
          </div>
          <p class="text-[#1e3a5f]/40 text-xs">
            Referencia: 1 kg ≈ 2.2 lbs · 1 cm ≈ 0.39 inches
          </p>
          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button type="button" onclick="goNext()" class="btn-primary"
              >Siguiente →</button
            >
          </div>
        </div>

        <!-- ===== STEP 4: Health Conditions ===== -->
        <div id="step-4" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Condiciones de salud
          </h3>

          <!-- Illnesses -->
          <div class="space-y-2">
            <label class="label-text">Enfermedades metabólicas</label>
            <div
              class="rounded-xl p-4 space-y-3"
              style="border: 1px solid rgba(30,58,95,0.12); background-color: #f8faff"
            >
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  value="Diabetes"
                  id="ill-diabetes"
                  class="illness-check w-4 h-4 rounded"
                  style="accent-color: #e8601c"
                />
                <span class="text-[#1e3a5f] text-sm">Diabetes</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  value="Resistencia a la insulina"
                  id="ill-insulin"
                  class="illness-check w-4 h-4 rounded"
                  style="accent-color: #e8601c"
                />
                <span class="text-[#1e3a5f] text-sm"
                  >Resistencia a la insulina</span
                >
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  value="Hipertensión"
                  id="ill-hyper"
                  class="illness-check w-4 h-4 rounded"
                  style="accent-color: #e8601c"
                />
                <span class="text-[#1e3a5f] text-sm">Hipertensión</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  value="Hipotiroidismo"
                  id="ill-thyroid"
                  class="illness-check w-4 h-4 rounded"
                  style="accent-color: #e8601c"
                />
                <span class="text-[#1e3a5f] text-sm">Hipotiroidismo</span>
              </label>
              <div class="border-t border-[#1e3a5f]/10 pt-3">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input
                    type="checkbox"
                    id="ill-none"
                    class="w-4 h-4 rounded"
                    style="accent-color: #e8601c"
                  />
                  <span class="text-[#1e3a5f] text-sm font-semibold"
                    >Ninguna de las anteriores</span
                  >
                </label>
              </div>
              <div class="space-y-1 pt-1">
                <label class="text-[#1e3a5f]/50 text-xs font-medium"
                  >Otra condición</label
                >
                <input
                  id="f-otherIllness"
                  type="text"
                  class="form-input text-sm"
                  placeholder="Especifica otra condición"
                />
              </div>
            </div>
          </div>

          <!-- Injury -->
          <div class="space-y-1.5">
            <label for="f-hasInjury" class="label-text">
              ¿Tienes alguna lesión? <span class="text-red-500">*</span>
            </label>
            <select
              id="f-hasInjury"
              class="form-input"
              onchange="toggleInjuryDetail()"
            >
              <option value="">Selecciona</option>
              <option value="no">No</option>
              <option value="yes">Sí</option>
            </select>
            <p id="err-hasInjury" class="err-msg hidden"></p>
          </div>

          <div id="injury-detail" class="hidden space-y-4">
            <div class="space-y-1.5">
              <label for="f-injuryDesc" class="label-text"
                >Describe tu lesión</label
              >
              <input
                id="f-injuryDesc"
                type="text"
                class="form-input"
                placeholder="Ej: Dolor de rodilla izquierda"
              />
            </div>
            <div class="space-y-1.5">
              <label for="f-doctorClearance" class="label-text">
                ¿Tienes autorización médica para hacer ejercicio?
                <span class="text-red-500">*</span>
              </label>
              <select id="f-doctorClearance" class="form-input">
                <option value="">Selecciona</option>
                <option value="yes">Sí</option>
                <option value="no">No</option>
              </select>
              <p id="err-doctorClearance" class="err-msg hidden"></p>
            </div>
          </div>

          <div class="space-y-1.5">
            <label for="f-meds" class="label-text">
              ¿Estás tomando algún medicamento? <span class="text-red-500"
                >*</span
              >
            </label>
            <select id="f-meds" class="form-input">
              <option value="">Selecciona</option>
              <option value="no">No</option>
              <option value="yes">Sí</option>
            </select>
            <p id="err-meds" class="err-msg hidden"></p>
          </div>

          <div class="space-y-1.5">
            <label for="f-pregnant" class="label-text">
              ¿Estás embarazada? <span class="text-red-500">*</span>
            </label>
            <select id="f-pregnant" class="form-input">
              <option value="">Selecciona</option>
              <option value="no">No</option>
              <option value="yes">Sí</option>
              <option value="na">No aplica</option>
            </select>
            <p id="err-pregnant" class="err-msg hidden"></p>
          </div>

          <div class="space-y-1.5">
            <label for="f-surgery" class="label-text">
              ¿Has tenido cirugía reciente? <span class="text-red-500">*</span>
            </label>
            <select id="f-surgery" class="form-input">
              <option value="">Selecciona</option>
              <option value="no">No</option>
              <option value="yes">Sí</option>
            </select>
            <p id="err-surgery" class="err-msg hidden"></p>
          </div>

          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button type="button" onclick="goNext()" class="btn-primary"
              >Siguiente →</button
            >
          </div>
        </div>

        <!-- ===== STEP 5: Activity & Goals ===== -->
        <div id="step-5" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Actividad y objetivos
          </h3>

          <div class="space-y-1.5">
            <label for="f-days" class="label-text">
              Días de entrenamiento por semana <span class="text-red-500"
                >*</span
              >
            </label>
            <select id="f-days" class="form-input">
              <option value="">Selecciona</option>
              <option value="0">Ninguno</option>
              <option value="1">1 día</option>
              <option value="2">2 días</option>
              <option value="3">3 días</option>
              <option value="4">4 días</option>
              <option value="5">5 días</option>
              <option value="6">6 días</option>
              <option value="7">7 días</option>
            </select>
            <p id="err-days" class="err-msg hidden"></p>
          </div>

          <div class="space-y-1.5">
            <label for="f-activity" class="label-text">
              Nivel de actividad <span class="text-red-500">*</span>
            </label>
            <select id="f-activity" class="form-input">
              <option value="">Selecciona tu nivel</option>
              <option value="sedentary">Sedentario</option>
              <option value="moderate">Moderado</option>
              <option value="active">Activo</option>
              <option value="very_active">Muy activo</option>
            </select>
            <p id="err-activity" class="err-msg hidden"></p>
          </div>

          <div class="space-y-1.5">
            <label for="f-objective" class="label-text">
              Objetivo principal <span class="text-red-500">*</span>
            </label>
            <select id="f-objective" class="form-input">
              <option value="">Selecciona tu objetivo</option>
              <option value="weight_loss">Bajar de peso</option>
              <option value="body_recomposition">Recomposición corporal</option>
              <option value="energy_increase">Aumentar energía</option>
              <option value="improve_habits">Mejorar hábitos</option>
              <option value="all">Todos los anteriores</option>
            </select>
            <p id="err-objective" class="err-msg hidden"></p>
          </div>

          <div class="space-y-1.5">
            <label for="f-weightToLose" class="label-text"
              >Peso que deseas perder (lbs)</label
            >
            <input
              id="f-weightToLose"
              type="number"
              step="0.1"
              min="0"
              class="form-input"
              placeholder="Ej: 20"
            />
          </div>

          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button type="button" onclick="goNext()" class="btn-primary"
              >Siguiente →</button
            >
          </div>
        </div>

        <!-- ===== STEP 6: Plan & Payment ===== -->
        <div id="step-6" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Plan y pago
          </h3>

          <!-- Plan info card -->
          <div
            class="rounded-2xl p-8"
            style="background: linear-gradient(135deg, rgba(79,111,232,0.08) 0%, rgba(124,58,237,0.08) 100%); border: 1px solid rgba(79,111,232,0.2)"
          >
            <p class="text-[#1e3a5f] font-black text-lg leading-tight">
              Reto Online Masivo
            </p>
            <p class="text-black text-sm mt-0.5">
              4 semanas · Entrenamiento + Nutrición + Mindset + Comunidad
            </p>
            <div class="flex items-baseline gap-3 mt-3">
              <p class="text-[#e8601c] font-black text-2xl">$28 USD</p>
              <p class="text-[#1e3a5f]/40 text-sm line-through">
                antes $53 USD
              </p>
            </div>
          </div>

          <div class="space-y-1.5">
            <label for="f-paymentMethod" class="label-text">
              Método de pago <span class="text-red-500">*</span>
            </label>
            <select id="f-paymentMethod" class="form-input">
              <option value="">Selecciona método de pago</option>
              <option value="zelle">Zelle</option>
              <option value="paypal">PayPal</option>
              <option value="western_union">Western Union</option>
              <option value="bank_transfer">Transferencia bancaria</option>
            </select>
            <p id="err-paymentMethod" class="err-msg hidden"></p>
          </div>

          <!-- File upload -->
          <div class="space-y-1.5">
            <label class="label-text">
              Comprobante de pago <span class="text-red-500">*</span>
            </label>
            <div
              id="upload-area"
              class="rounded-xl p-6 text-center cursor-pointer transition-colors"
              style="border: 2px dashed rgba(30,58,95,0.2)"
              onclick="triggerFileInput()"
              onmouseenter="this.style.borderColor='#e8601c'"
              onmouseleave="this.style.borderColor='rgba(30,58,95,0.2)'"
            >
              <input
                id="f-proof-file"
                type="file"
                accept="image/jpeg,image/png,image/webp,application/pdf"
                class="hidden"
                onchange="handleFileChange(event)"
              />
              <div id="upload-placeholder">
                <div class="text-3xl mb-2">📎</div>
                <p class="text-[#1e3a5f]/70 text-sm font-medium">
                  Haz clic para subir tu comprobante
                </p>
                <p class="text-[#1e3a5f]/40 text-xs mt-1">
                  JPG, PNG, WebP o PDF (máx. 10MB)
                </p>
              </div>
              <div id="upload-selected" class="hidden">
                <div class="text-3xl mb-2">✅</div>
                <p
                  id="upload-filename"
                  class="text-[#1e3a5f] text-sm font-semibold"
                >
                </p>
                <p class="text-[#1e3a5f]/40 text-xs mt-1">
                  Haz clic para cambiar el archivo
                </p>
              </div>
            </div>
            <p id="err-proof" class="err-msg hidden"></p>
          </div>

          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button
              id="btn-step6"
              type="button"
              onclick="handleStep6Next()"
              class="btn-primary"
            >
              Siguiente →
            </button>
          </div>
        </div>

        <!-- ===== STEP 7: Summary & Terms ===== -->
        <div id="step-7" class="hidden px-8 py-6 space-y-5">
          <h3
            class="font-black text-[#1e3a5f] text-base uppercase tracking-wide"
          >
            Resumen y términos
          </h3>

          <!-- Summary box -->
          <div
            id="summary-box"
            class="rounded-2xl p-4 space-y-2.5 text-sm"
            style="background-color: #f8faff; border: 1px solid rgba(30,58,95,0.1)"
          >
          </div>

          <!-- Terms -->
          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="f-terms"
              class="w-4 h-4 mt-0.5 flex-shrink-0"
              style="accent-color: #e8601c"
            />
            <label
              for="f-terms"
              class="text-[#1e3a5f]/70 text-sm leading-relaxed cursor-pointer"
            >
              Acepto los
              <button
                type="button"
                onclick="openTermsModal()"
                class="font-semibold underline underline-offset-2 hover:opacity-80"
                style="color: #e8601c"
              >
                términos y condiciones
              </button>
              del servicio.
            </label>
          </div>
          <p id="err-terms" class="err-msg hidden">
            Debes aceptar los términos y condiciones para continuar.
          </p>

          <div
            id="submit-error"
            class="hidden rounded-xl p-3 text-sm"
            style="background-color: #fef2f2; border: 1px solid #fecaca; color: #dc2626"
          >
          </div>

          <div class="flex gap-3 justify-end pt-2">
            <button type="button" onclick="goPrev()" class="btn-outline"
              >← Atrás</button
            >
            <button
              id="btn-submit"
              type="button"
              onclick="handleSubmit()"
              class="btn-primary"
            >
              Enviar solicitud
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Terms Modal -->
    <dialog
      id="terms-modal"
      class="fixed inset-0 z-50 w-full max-w-2xl mx-auto my-8 rounded-2xl bg-white shadow-2xl p-0 backdrop:bg-black/60"
    >
      <div
        class="flex items-center justify-between px-8 py-5 sticky top-0 bg-white rounded-t-2xl z-10"
        style="border-bottom: 1px solid rgba(30,58,95,0.08)"
      >
        <h2 class="font-black text-[#1e3a5f] text-base uppercase tracking-wide">
          Términos y Condiciones
        </h2>
        <button
          onclick="closeTermsModal()"
          class="w-8 h-8 rounded-full flex items-center justify-center font-black text-lg transition-colors"
          style="background-color: #f3f4f6; color: #6b7280"
          onmouseenter="this.style.backgroundColor='#e5e7eb'"
          onmouseleave="this.style.backgroundColor='#f3f4f6'"
          aria-label="Cerrar"
        >
          ×
        </button>
      </div>
      <div class="px-8 py-6 overflow-y-auto" style="max-height: 60vh">
        <pre
          class="whitespace-pre-wrap font-jakarta text-sm leading-relaxed"
          style="color: rgba(30,58,95,0.8)">{terminos}</pre>
      </div>
      <div
        class="px-8 py-5 sticky bottom-0 bg-white rounded-b-2xl"
        style="border-top: 1px solid rgba(30,58,95,0.08)"
      >
        <button onclick="acceptTermsFromModal()" class="btn-primary w-full">
          Entendido
        </button>
      </div>
    </dialog>
  </div>

  <style is:global>
    body {
      background: linear-gradient(
        140deg,
        #4f6fe8 0%,
        #5b21b6 50%,
        #7c3aed 100%
      ) !important;
      min-height: 100vh !important;
    }
    .form-input {
      width: 100%;
      border: 1px solid rgba(30, 58, 95, 0.2);
      border-radius: 0.75rem;
      padding: 0.625rem 1rem;
      color: #1e3a5f;
      background-color: white;
      font-size: 0.875rem;
      transition: all 0.15s;
      outline: none;
      appearance: auto;
    }
    .form-input:focus {
      border-color: #4f6fe8;
      box-shadow: 0 0 0 3px rgba(79, 111, 232, 0.15);
    }
    .form-input.error {
      border-color: #ef4444;
    }
    .label-text {
      display: block;
      font-size: 0.8125rem;
      font-weight: 700;
      color: #1e3a5f;
    }
    .err-msg {
      font-size: 0.75rem;
      color: #ef4444;
    }
    .btn-primary {
      background-color: #e8601c;
      color: white;
      font-weight: 900;
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.75rem 2rem;
      border-radius: 9999px;
      transition: all 0.15s;
      cursor: pointer;
      border: none;
    }
    .btn-primary:hover {
      background-color: #cf5218;
      transform: scale(1.02);
    }
    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    .btn-outline {
      border: 2px solid rgba(30, 58, 95, 0.25);
      color: #1e3a5f;
      font-weight: 900;
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.625rem 1.5rem;
      border-radius: 9999px;
      transition: all 0.15s;
      cursor: pointer;
      background: transparent;
    }
    .btn-outline:hover {
      background-color: rgba(30, 58, 95, 0.05);
    }
  </style>

  <script is:inline>
    // ── Countries ──────────────────────────────────────────────────────────────
    const COUNTRIES = [
      "Argentina",
      "Bolivia",
      "Brasil",
      "Canadá",
      "Chile",
      "Colombia",
      "Costa Rica",
      "Cuba",
      "Ecuador",
      "El Salvador",
      "España",
      "Estados Unidos",
      "Guatemala",
      "Haití",
      "Honduras",
      "Jamaica",
      "México",
      "Nicaragua",
      "Panamá",
      "Paraguay",
      "Perú",
      "Puerto Rico",
      "República Dominicana",
      "Uruguay",
      "Venezuela",
      "Otro",
    ];

    const countrySelect = document.getElementById("f-country");
    COUNTRIES.forEach((c) => {
      const opt = document.createElement("option");
      opt.value = c;
      opt.textContent = c;
      countrySelect.appendChild(opt);
    });

    // ── State ──────────────────────────────────────────────────────────────────
    let currentStep = 1;
    const TOTAL_STEPS = 7;

    const state = {
      email: "",
      firstName: "",
      lastName: "",
      age: "",
      gender: "",
      phoneNumber: "",
      residenceCountry: "",
      weight: "",
      height: "",
      selectedIllnesses: [],
      otherIllness: "",
      hasNoIllness: false,
      hasInjury: "",
      injuryDescription: "",
      doctorClearance: "",
      isTakingMedicament: "",
      isPregnant: "",
      recentSurgery: "",
      daysTrainingPerWeek: "",
      activityLevel: "",
      principalObjective: "",
      weightToLose: "",
      selectedPlan: "reto-masivo-4-semanas",
      paymentMethod: "",
      paymentProofUrl: "",
      paymentProofFile: null,
      needsUpload: false,
    };

    // ── Progress ───────────────────────────────────────────────────────────────
    function updateProgress(step) {
      for (let i = 1; i <= TOTAL_STEPS; i++) {
        const bar = document.getElementById("bar-" + i);
        if (bar) {
          bar.style.backgroundColor =
            i <= step ? "#e8601c" : "rgba(30,58,95,0.1)";
        }
      }
      document.getElementById("step-label").textContent =
        "Paso " + step + " de " + TOTAL_STEPS;
    }

    function showStep(step) {
      document.getElementById("step-" + currentStep).classList.add("hidden");
      document.getElementById("step-" + step).classList.remove("hidden");
      currentStep = step;
      updateProgress(step);
      document
        .getElementById("form-card")
        .scrollIntoView({ behavior: "smooth", block: "start" });
    }

    // ── Save step values to state ──────────────────────────────────────────────
    function saveStepValues(step) {
      if (step === 1) {
        state.email = document.getElementById("f-email").value.trim();
      } else if (step === 2) {
        state.firstName = document.getElementById("f-firstName").value.trim();
        state.lastName = document.getElementById("f-lastName").value.trim();
        state.age = document.getElementById("f-age").value;
        state.gender = document.getElementById("f-gender").value;
        state.phoneNumber = document.getElementById("f-phone").value.trim();
        state.residenceCountry = document.getElementById("f-country").value;
      } else if (step === 3) {
        state.weight = document.getElementById("f-weight").value;
        state.height = document.getElementById("f-height").value;
      } else if (step === 4) {
        const checked = document.querySelectorAll(".illness-check:checked");
        state.selectedIllnesses = Array.from(checked).map((el) => el.value);
        state.hasNoIllness = document.getElementById("ill-none").checked;
        state.otherIllness = document
          .getElementById("f-otherIllness")
          .value.trim();
        state.hasInjury = document.getElementById("f-hasInjury").value;
        state.injuryDescription = document
          .getElementById("f-injuryDesc")
          .value.trim();
        state.doctorClearance =
          document.getElementById("f-doctorClearance").value;
        state.isTakingMedicament = document.getElementById("f-meds").value;
        state.isPregnant = document.getElementById("f-pregnant").value;
        state.recentSurgery = document.getElementById("f-surgery").value;
      } else if (step === 5) {
        state.daysTrainingPerWeek = document.getElementById("f-days").value;
        state.activityLevel = document.getElementById("f-activity").value;
        state.principalObjective = document.getElementById("f-objective").value;
        state.weightToLose = document.getElementById("f-weightToLose").value;
      } else if (step === 6) {
        state.paymentMethod = document.getElementById("f-paymentMethod").value;
      }
    }

    // ── Validation ─────────────────────────────────────────────────────────────
    function clearErrors() {
      document.querySelectorAll("[id^='err-']").forEach((el) => {
        el.classList.add("hidden");
        el.textContent = "";
      });
      document.querySelectorAll(".form-input").forEach((el) => {
        el.classList.remove("error");
      });
    }

    function showError(fieldId, msg) {
      const err = document.getElementById("err-" + fieldId);
      if (err) {
        err.textContent = msg;
        err.classList.remove("hidden");
      }
      const input = document.getElementById("f-" + fieldId);
      if (input) input.classList.add("error");
    }

    function validateStep(step) {
      clearErrors();
      let valid = true;

      if (step === 1) {
        const email = document.getElementById("f-email").value.trim();
        if (!email || !email.includes("@")) {
          showError("email", "Ingresa un correo electrónico válido");
          valid = false;
        }
      } else if (step === 2) {
        if (!document.getElementById("f-firstName").value.trim()) {
          showError("firstName", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-lastName").value.trim()) {
          showError("lastName", "Este campo es requerido");
          valid = false;
        }
        const age = document.getElementById("f-age").value;
        if (!age || parseInt(age) < 1) {
          showError("age", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-gender").value) {
          showError("gender", "Este campo es requerido");
          valid = false;
        }
      } else if (step === 3) {
        const w = document.getElementById("f-weight").value;
        const h = document.getElementById("f-height").value;
        if (!w || parseFloat(w) <= 0) {
          showError("weight", "Este campo es requerido");
          valid = false;
        }
        if (!h || parseFloat(h) <= 0) {
          showError("height", "Este campo es requerido");
          valid = false;
        }
      } else if (step === 4) {
        if (!document.getElementById("f-hasInjury").value) {
          showError("hasInjury", "Este campo es requerido");
          valid = false;
        }
        if (
          document.getElementById("f-hasInjury").value === "yes" &&
          !document.getElementById("f-doctorClearance").value
        ) {
          showError("doctorClearance", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-meds").value) {
          showError("meds", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-pregnant").value) {
          showError("pregnant", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-surgery").value) {
          showError("surgery", "Este campo es requerido");
          valid = false;
        }
      } else if (step === 5) {
        if (!document.getElementById("f-days").value) {
          showError("days", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-activity").value) {
          showError("activity", "Este campo es requerido");
          valid = false;
        }
        if (!document.getElementById("f-objective").value) {
          showError("objective", "Este campo es requerido");
          valid = false;
        }
      }

      return valid;
    }

    function validateStep6() {
      clearErrors();
      let valid = true;
      if (!document.getElementById("f-paymentMethod").value) {
        showError("paymentMethod", "Selecciona un método de pago");
        valid = false;
      }
      if (!state.paymentProofFile && !state.paymentProofUrl) {
        const err = document.getElementById("err-proof");
        err.textContent = "Sube el comprobante de pago";
        err.classList.remove("hidden");
        valid = false;
      }
      return valid;
    }

    // ── Navigation ─────────────────────────────────────────────────────────────
    function goNext() {
      if (!validateStep(currentStep)) return;
      saveStepValues(currentStep);
      const next = currentStep + 1;
      showStep(next);
      if (next === TOTAL_STEPS) populateSummary();
    }

    function goPrev() {
      showStep(currentStep - 1);
    }

    // ── Illness toggle ─────────────────────────────────────────────────────────
    document.getElementById("ill-none").addEventListener("change", function () {
      const illChecks = document.querySelectorAll(".illness-check");
      if (this.checked) {
        illChecks.forEach((el) => {
          el.checked = false;
          el.disabled = true;
        });
        document.getElementById("f-otherIllness").disabled = true;
        document.getElementById("f-otherIllness").value = "";
      } else {
        illChecks.forEach((el) => (el.disabled = false));
        document.getElementById("f-otherIllness").disabled = false;
      }
    });

    document.querySelectorAll(".illness-check").forEach((el) => {
      el.addEventListener("change", function () {
        if (this.checked) {
          document.getElementById("ill-none").checked = false;
        }
      });
    });

    // ── Injury detail toggle ───────────────────────────────────────────────────
    function toggleInjuryDetail() {
      const hasInjury = document.getElementById("f-hasInjury").value;
      document
        .getElementById("injury-detail")
        .classList.toggle("hidden", hasInjury !== "yes");
    }

    // ── File upload ────────────────────────────────────────────────────────────
    function triggerFileInput() {
      document.getElementById("f-proof-file").click();
    }

    function handleFileChange(event) {
      const file = event.target.files[0];
      if (!file) return;
      state.paymentProofFile = file;
      state.needsUpload = true;
      document.getElementById("upload-placeholder").classList.add("hidden");
      document.getElementById("upload-selected").classList.remove("hidden");
      document.getElementById("upload-filename").textContent = file.name;
      const err = document.getElementById("err-proof");
      err.classList.add("hidden");
      err.textContent = "";
    }

    async function handleStep6Next() {
      if (!validateStep6()) return;

      // If file was already uploaded and no new file selected, just advance
      if (!state.needsUpload && state.paymentProofUrl) {
        state.paymentMethod = document.getElementById("f-paymentMethod").value;
        showStep(7);
        populateSummary();
        return;
      }

      const btn = document.getElementById("btn-step6");
      btn.disabled = true;
      btn.textContent = "Subiendo...";

      try {
        const fd = new FormData();
        fd.append("file", state.paymentProofFile);

        const res = await fetch("/api/upload-payment-proof", {
          method: "POST",
          body: fd,
        });

        const data = await res.json();

        if (!res.ok || data.error) {
          const err = document.getElementById("err-proof");
          err.textContent = data.error || "Error al subir el archivo";
          err.classList.remove("hidden");
          return;
        }

        state.paymentProofUrl = data.url;
        state.paymentMethod = document.getElementById("f-paymentMethod").value;
        state.needsUpload = false;

        showStep(7);
        populateSummary();
      } catch {
        const err = document.getElementById("err-proof");
        err.textContent = "Error al subir el archivo. Intenta de nuevo.";
        err.classList.remove("hidden");
      } finally {
        btn.disabled = false;
        btn.textContent = "Siguiente →";
      }
    }

    // ── Summary ────────────────────────────────────────────────────────────────
    function populateSummary() {
      const methodLabels = {
        zelle: "Zelle",
        paypal: "PayPal",
        western_union: "Western Union",
      };
      const paymentLabel =
        methodLabels[state.paymentMethod] || state.paymentMethod;

      document.getElementById("summary-box").innerHTML = `
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Correo:</span>
          <span style="color:#1e3a5f;font-weight:600">${state.email}</span>
        </div>
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Nombre:</span>
          <span style="color:#1e3a5f;font-weight:600">${state.firstName} ${state.lastName}</span>
        </div>
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Plan:</span>
          <span style="color:#1e3a5f;font-weight:600">Reto Online Masivo · 4 semanas</span>
        </div>
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Monto:</span>
          <span style="color:#e8601c;font-weight:900">$28 USD</span>
        </div>
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Método de pago:</span>
          <span style="color:#1e3a5f;font-weight:600">${paymentLabel}</span>
        </div>
        <div class="flex justify-between items-center">
          <span style="color:rgba(30,58,95,0.5)">Comprobante:</span>
          <span style="color:#16a34a;font-weight:600">✓ Subido</span>
        </div>
      `;
    }

    // ── Terms modal ────────────────────────────────────────────────────────────
    function openTermsModal() {
      document.getElementById("terms-modal").showModal();
    }

    function closeTermsModal() {
      document.getElementById("terms-modal").close();
    }

    function acceptTermsFromModal() {
      document.getElementById("f-terms").checked = true;
      document.getElementById("err-terms").classList.add("hidden");
      closeTermsModal();
    }

    document.getElementById("terms-modal").addEventListener("click", (e) => {
      if (e.target === document.getElementById("terms-modal"))
        closeTermsModal();
    });

    // ── Final submit ───────────────────────────────────────────────────────────
    async function handleSubmit() {
      const termsChecked = document.getElementById("f-terms").checked;
      if (!termsChecked) {
        document.getElementById("err-terms").classList.remove("hidden");
        return;
      }
      document.getElementById("err-terms").classList.add("hidden");

      const btn = document.getElementById("btn-submit");
      btn.disabled = true;
      btn.textContent = "Enviando...";

      const submitErr = document.getElementById("submit-error");
      submitErr.classList.add("hidden");
      submitErr.textContent = "";

      const payload = {
        email: state.email,
        firstName: state.firstName,
        lastName: state.lastName,
        age: state.age ? parseInt(state.age) : undefined,
        gender: state.gender || undefined,
        phoneNumber: state.phoneNumber || undefined,
        residenceCountry: state.residenceCountry || undefined,
        weight: state.weight ? Math.round(parseFloat(state.weight)) : undefined,
        height: state.height ? Math.round(parseFloat(state.height)) : undefined,
        hasInjury: state.hasInjury === "yes",
        injuryDescription:
          state.hasInjury === "yes" ? state.injuryDescription : undefined,
        doctorClearance: state.doctorClearance === "yes",
        isTakingMedicament: state.isTakingMedicament === "yes",
        isPregnant: state.isPregnant === "yes",
        recentSurgery: state.recentSurgery === "yes",
        daysTrainingPerWeek: state.daysTrainingPerWeek
          ? parseInt(state.daysTrainingPerWeek)
          : undefined,
        activityLevel: state.activityLevel || undefined,
        principalObjective: state.principalObjective || undefined,
        weightToLose: state.weightToLose
          ? Math.round(parseFloat(state.weightToLose))
          : undefined,
        illnessNames: state.selectedIllnesses,
        otherIllness: state.otherIllness || undefined,
        selectedPlan: state.selectedPlan,
        paymentMethod: state.paymentMethod,
        paymentProofUrl: state.paymentProofUrl,
      };

      try {
        const res = await fetch("/api/submit-application", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (data.error) {
          submitErr.textContent = data.message;
          submitErr.classList.remove("hidden");
          btn.disabled = false;
          btn.textContent = "Enviar solicitud";
          return;
        }

        document.getElementById("form-card").classList.add("hidden");
        document.getElementById("success-state").classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      } catch {
        submitErr.textContent =
          "Error al enviar la solicitud. Por favor intenta de nuevo.";
        submitErr.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Enviar solicitud";
      }
    }

    // ── Init ───────────────────────────────────────────────────────────────────
    updateProgress(1);
  </script>
</Layout>
